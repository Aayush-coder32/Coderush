# Production Environment Variables Template
# ============================================
# Copy this file to .env and fill in all required values
# NEVER commit .env to git repository

# ═══════════════════════════════════════════════════════════════
# REQUIRED - Application must not start without these
# ═══════════════════════════════════════════════════════════════

# Port configuration
PORT=5000

# Node environment
NODE_ENV=production

# MongoDB Connection String (REQUIRED)
# Use MongoDB Atlas for production
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_campus_os

# JWT Secret (REQUIRED - use strong random 32+ character string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

JWT_EXPIRES_IN=7d

# Frontend URL (REQUIRED - must match deployment domain)
CLIENT_URL=https://yourdomain.com

# ═══════════════════════════════════════════════════════════════
# OPTIONAL - Features disabled if not configured
# ═══════════════════════════════════════════════════════════════

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Razorpay Payment Gateway (India)
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx

# OpenAI (for AI features: chatbot, recommendations, brain feed)
OPENAI_API_KEY=sk-xxx

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Smart Campus <noreply@smartcampus.local>"

# Notifications
ENABLE_ATTENDANCE_ALERTS=true

# ═══════════════════════════════════════════════════════════════
# PRODUCTION SECURITY NOTES
# ═══════════════════════════════════════════════════════════════
# 
# 1. JWT_SECRET
#    - MUST be 32+ characters
#    - MUST be random and unique
#    - MUST be different from development
#    - Regenerate for security incident
#
# 2. DATABASE
#    - Use MongoDB Atlas (managed service)
#    - Enable network access restrictions
#    - Enable encryption at rest
#    - Enable encryption in transit (TLS)
#    - Setup automated backups
#
# 3. API KEYS
#    - Use production keys/credentials
#    - Save sensitive files securely
#    - Rotate periodically
#    - Use secret management (AWS Secrets Manager, etc.)
#
# 4. CORS
#    - CLIENT_URL must point to actual frontend domain
#    - Verify domain matches deployment
#    - No wildcards in production
#
# 5. HTTPS
#    - Enable SSL/TLS certificate
#    - Redirect HTTP to HTTPS
#    - Use strong ciphers
#    - Enable HSTS header

# ═══════════════════════════════════════════════════════════════
# Deployment Checklist
# ═══════════════════════════════════════════════════════════════
# 
# Before deploying to production:
# [ ] All REQUIRED variables above are filled
# [ ] NODE_ENV is set to 'production'
# [ ] JWT_SECRET is strong (32+ chars, random)
# [ ] MONGODB_URI points to production database
# [ ] CLIENT_URL is HTTPS and matches domain
# [ ] All external services configured
# [ ] .env file is NOT committed to git
# [ ] .env file has restrictive file permissions (chmod 600)
# [ ] Backup/rollback plan is ready
# [ ] Database backups are enabled
# [ ] Monitoring and alerts are setup
# [ ] SSL/TLS certificate is valid
