# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (local or Atlas)
MONGODB_URI=
#
# Atlas tips:
# - Password mein @ # : / ? ho to URL-encode karo (@ → %40).
# - Agar error aaye: querySrv ECONNREFUSED → DNS issue. Try: ipconfig /flushdns,
#   mobile hotspot, ya Atlas se "standard" (non-SRV) string:
#   mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/DB?tls=true&replicaSet=...
#   (Atlas → Database → Connect → Drivers — kabhi "SRV" toggle off milta hai;
#    warna "Connect with MongoDB Compass" / cluster details se 3 hostnames copy karo.)

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS and Stripe redirects)
CLIENT_URL=http://localhost:3001

# Cloudinary (optional — without these, event images use a placeholder)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe test keys (optional — without Stripe or Razorpay, paid events fall back to "simulate payment" in dev)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Razorpay test keys (optional — use Test Mode keys from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
# Optional: UPI VPA + 10-digit mobile for checkout prefill (overrides frontend defaults)
# RAZORPAY_PREFILL_VPA=bhattayush241-1@okaxis
# RAZORPAY_PREFILL_CONTACT=9876543210

# OpenAI (optional — Brain feed narrative, chatbot, event recommendation blurbs)
OPENAI_API_KEY=

# Attendance push alerts (in-app + socket). Set to false to disable auto-notify on prediction API.
ENABLE_ATTENDANCE_ALERTS=true

# Email notifications (optional — uses Ethereal test account if unset)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Smart Campus <noreply@smartcampus.local>"
